    <worksheet name='TEST'>
      <table>
        <view>
          <datasources>
            <datasource caption='HumanResources (2)' name='federated.0dymbf119do9bg16acqra1fj4bbs' />
          </datasources>
          <datasource-dependencies datasource='federated.0dymbf119do9bg16acqra1fj4bbs'>
            <column datatype='date' name='[Birth Date]' role='dimension' type='ordinal' />
            <column caption='Location' datatype='string' name='[Calculation_0923908729954311]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &apos;New York&apos; THEN &apos;HQ&apos;&#13;&#10;    ELSE &apos;Branch&apos;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='integer' name='[Calculation_0923908748353547]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [Birth Date], TODAY())' />
            </column>
            <column caption='Age Groups' datatype='string' name='[Calculation_0923908748914700]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0923908748353547] &lt; 25 THEN &apos;&gt;25&apos;&#13;&#10;ELSEIF [Calculation_0923908748353547] &gt;=25 AND [Calculation_0923908748353547] &lt; 35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_0923908748353547] &gt;=35 AND [Calculation_0923908748353547] &lt; 45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_0923908748353547] &gt;=45 AND [Calculation_0923908748353547] &lt; 55 THEN &apos;45-54&apos;&#13;&#10;ELSEIF [Calculation_0923908748353547] &gt;=55 THEN &apos;55+&apos;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Employee ID]' role='dimension' type='nominal' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
